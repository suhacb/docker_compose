# --- OpenClaw ---
OPENCLAW_PORT=9051
OPENCLAW_UI_PORT=9050
LOG_LEVEL=info
OPENCLAW_GATEWAY_CONTROLUI_ALLOWEDORIGINS=http://localhost:9050,http://127.0.0.1:9050
OPENCLAW_CODE_DIR=

# --- LLM (Ollama on host) ---
LLM_PROVIDER=ollama
OLLAMA_BASE_URL=http://host.docker.internal:11434
SEARXNG_CODE_DIR=

# --- SearXNG ---
SEARXNG_BASE_URL=http://localhost:8080/
SEARXNG_INSTANCE_NAME=openclaw-searxng

# --- Optional tuning ---
# (you can expand later)